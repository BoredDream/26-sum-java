<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.training.system.info.mapper.DataBackupMapper">

    <resultMap id="BackupVOMap" type="com.training.system.info.vo.BackupVO">
        <id property="backupId" column="backup_id"/>
        <result property="backupTime" column="backup_time"/>
        <result property="filePath" column="file_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="operatorId" column="operator_id"/>
        <result property="operatorName" column="operator_name"/>
    </resultMap>

    <insert id="insert" parameterType="com.training.system.info.entity.DataBackup" useGeneratedKeys="true" keyProperty="backupId">
        INSERT INTO data_backup (backup_time, file_path, file_size, operator_id)
        VALUES (NOW(), #{filePath}, #{fileSize}, #{operatorId})
    </insert>

    <delete id="deleteById">
        DELETE FROM data_backup WHERE backup_id=#{backupId}
    </delete>

    <select id="selectById" resultType="com.training.system.info.entity.DataBackup">
        SELECT * FROM data_backup WHERE backup_id=#{backupId}
    </select>

    <select id="selectPage" resultMap="BackupVOMap">
        SELECT b.*, t.teacher_name AS operator_name FROM data_backup b
        LEFT JOIN teacher t ON b.operator_id = t.teacher_id
        ORDER BY b.backup_time DESC LIMIT #{offset},#{size}
    </select>

    <select id="countPage" resultType="long">
        SELECT COUNT(*) FROM data_backup
    </select>

    <select id="selectByTimeBefore" resultType="com.training.system.info.entity.DataBackup">
        SELECT * FROM data_backup WHERE backup_time &lt; #{cutoff}
    </select>
</mapper>
